---
/**
 * pages/engager-motiver.astro — Engager et motiver
 */
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Engager et motiver"
  description="Stimulez l'implication et la motivation de vos collaborateurs grâce à la gamification Loooper!."
  ogUrl="https://loooper.fr/engager-motiver"
  currentPage="engager-motiver"
>
 <section class="mainPageTitle mainPageTitlePurple">
            <h1 class="h1 container-width white-border black">Loooper! c’est
                <div class="paterneTitleContainer"><span class="paterneTitle paterneTitleBlue">engager </span><span
                        class="paterneTitleContour">engager </span></div>
                <div class="paterneTitleContainer"><span class="paterneTitle paterneTitleBlue">et </span><span
                        class="paterneTitleContour">et </span></div>
                <div class="paterneTitleContainer"><span class="paterneTitle paterneTitleBlue">motiver</span><span
                        class="paterneTitleContour">motiver</span></div>
            </h1>
        </section>
        <div class="container-width ariane-net h3"><a href="/">Accueil </a>
            <p class="h3">></p> <a href="/besoins/">Vos besoins</a>
            <p class="h3">></p><a href="/engager-motiver/"
                class="end-chield highlight-no-annim blue black-border-small"> Engager et motiver </a>
        </div>

        <div class="large-spacing"></div>


        <section class="container-width text-basical-container">
            <article class="text-basical-container-text-long">
                <div>
                    <h2 class="h2 black white-border">Créer de l’engagement à travers une expérience mémorable
                        interactive ?
                    </h2>
                    <div class="small-medium-spacing"></div>
                    <p>
                        Chez <b>Loooper!</b>, nous croyons que le jeu est un outil efficace pour <b
                            class="highlight orange">motiver, engager et fidéliser</b>. Nous convertissons vos contenus
                        en <b class="highlight purple">une expérience mémorable</b> qui <b>capte l'attention</b> et
                        suscite l'envie d'en <b>découvrir davantage</b>.
                        <b>La gamification</b> offre à votre public la possibilité d'établir <b
                            class="highlight blue">une connexion avec vos produits, services ou communications,</b> afin
                        de <b>dynamiser</b> une communauté, mettre en <b>valeur un produit</b> ou orchestrer <b>un
                            événement</b>.
                    </p>
                </div>
            </article>
            <article class="text-basical-container-emojie">
                <div class="emojie-img-line-container-besoin-child">
                    <div class="emojie-img-line-besoin-child star">
                        <img src="/svg/besoin/starYellowType2.svg" alt="Image representant des étoile">
                    </div>
                    <img class="emojie-img-line-besoin-child" src="/svg/besoin/starPodium.svg"
                        alt="Image representant une etoile sur un podium">
                    <div class="emojie-img-line-besoin-child star2">
                        <img src="/svg/besoin/starYellowType1.svg" alt="Image representant des étoile">
                    </div>
                </div>

            </article>
        </section>

        <div class="large-spacing"></div>

        <div class="backgroundBrushType1">
            <section class="container-width long-card-container">
                <h2 class="h2 black white-border">Les formats qui motivent avec la gamification</h2>
                <div class="small-medium-spacing"></div>
                <div class="long-card-wrapper">
                    <article class="long-card long-card-orange">
                        <img src="/img/long-card/mini-jeu.jpg" alt="image representative d'un Mini-jeu">
                        <div class="long-card-text-content">
                            <div>
                                <h3 class="h2 black white-border highlight-no-annim orange"
                                    id="book-page-part-1-container-title">
                                    Mini-jeu</h3>
                            </div>
                            <p class="black">Captez <b>l’attention</b>, divertissez et <b>dynamisez</b> un site
                                internet, une application ou un support de communication.</p>
                            <button data-modal="modal-mini-jeu" aria-haspopup="dialog"
                                class="text-typo btn-project btn-modal btn-white-background"
                                aria-label="En savoir plus sur les Mini-jeu">
                                <span>En savoir plus</span> </button>
                        </div>
                    </article>

                    <article class="long-card long-card-purple">
                        <img src="/img/long-card/story.jpg" alt="image representative d'une Histoire interactive">
                        <div class="long-card-text-content">
                            <div>
                                <h3 class="h2 black white-border highlight-no-annim purple"
                                    id="book-page-part-1-container-title">
                                    Histoire interactive</h3>
                            </div>
                            <p class="black">Plongez dans <b>un univers narratif immersif</b> et créez <b>une expérience
                                    mémorable</b> à travers vos choix.</p>
                            <button data-modal="modal-histoire-interactive" aria-haspopup="dialog"
                                class="text-typo btn-project btn-modal btn-white-background"
                                aria-label="En savoir plus sur les Histoire interactive">
                                <span>En savoir plus</span> </button>
                        </div>
                    </article>

                    <article class="long-card long-card-blue">
                        <img src="/img/long-card/geocaching.jpg" alt="image representative du Géocaching">
                        <div class="long-card-text-content">
                            <div>
                                <h3 class="h2 black white-border highlight-no-annim blue"
                                    id="book-page-part-1-container-title">
                                    Géocaching</h3>
                            </div>
                            <p class="black">Partez à <b>la découverte</b> d’un lieu, résolvez <b>des énigmes</b> sur le
                                terrain et animez <b>une communauté ou un événement</b>.
                            </p>
                            <button data-modal="modal-geocaching" aria-haspopup="dialog"
                                class="text-typo btn-project btn-modal btn-white-background"
                                aria-label="En savoir plus sur le Géocaching">
                                <span>En savoir plus</span> </button>
                        </div>
                    </article>
                </div>
                <div class="small-medium-spacing"></div>
                <a href="/formats/" class="text-typo btn-project btn-white-background">
                    <span>Découvrir nos autres formats</span>
                </a>
            </section>
        </div>

        <div class="large-spacing"></div>

        <div class="zoom-container-center">
            <div class="zoom-container background-interogation background-interogation-purple">
                <section class="container-width">
                    <h2 class="h2 black">Des questions sur l'engagement par le jeu ?
                    </h2>
                    <div class="small-medium-spacing"></div>
                    <div class="wrapper-faq-container-info">
                        <div class="wrapper-faq-container-info-row">
                            <article class="faq-container-info">
                                <div class="faq-header">
                                    <div>
                                        <div class="faq-arrow faq-arrow-orange">
                                            <div class="faq-arrow-1"></div>
                                            <div class="faq-arrow-2"></div>
                                        </div>
                                    </div>
                                    <h3 class="h3 black">L’engagement par le jeu fonctionne-t-il uniquement sur le court
                                        terme ?
                                    </h3>
                                </div>
                                <p class="black">
                                    <b>Non</b>. Selon vos objectifs, une expérience peut être pensée pour <b>un
                                        événement
                                        ponctuel</b> (lancement de produit, salon, campagne) ou pour <b>un engagement
                                        permanent</b> (plateforme gamifiée, animation communautaire).
                                </p>
                            </article>
                        </div>
                        <div class="wrapper-faq-container-info-row">
                            <article class="faq-container-info">
                                <div class="faq-header">
                                    <div>
                                        <div class="faq-arrow faq-arrow-purple">
                                            <div class="faq-arrow-1"></div>
                                            <div class="faq-arrow-2"></div>
                                        </div>
                                    </div>
                                    <h3 class="h3 black">
                                        Comment la gamification peut-elle créer de la fidélisation ?</h3>
                                </div>
                                <p class="black">
                                    En rendant l’expérience interactive et mémorable, vos publics ressentent <b>une
                                        affection positive</b> envers votre projet. Cela favorise <b>l’attachement</b>
                                    et
                                    encourage <b>la fidélité</b> sur le long terme.
                                </p>
                            </article>
                        </div>
                    </div>
                </section>
            </div>
        </div>

        <div id="modal-mini-jeu" class="modal" role="dialog" aria-modal="true" aria-labelledby="modal-mini-jeu-title">
            <div class="modal-header">
                <div class="modal-header-null-object"></div>
                <h2 class="h1 black header-modal-tilte">
                    <div class="paterneTitleContainer"><span>Mini-jeu</span><span
                            class="paterneTitleContour">Mini-jeu</span></div>
                </h2><button class="btn-close" aria-label="Fermer">
                    <div class="close-line"></div>
                    <div class="close-line"></div>
                </button>
            </div>

            <div>
                <div class="modal-container modal-orange">

                    <h3 id="modal-mini-jeu-interactive" class="h2 black sub-title-modal">Transformez une visite en <span
                            class="highlight-no-annim orange white-border">aventure !</span></h3>
                    <div class="modal-container-content">
                        <div class="modal-container-text">
                            <div class="modal-container-text-paragraph">
                                <div class="text-paragraph-emojie"><img src="/svg/modalEmojie/interogation.svg"
                                        alt="Image représentant un point d'interogation">
                                    <h4 class="h3 black">C’est quoi ?</h4>
                                </div>
                                <p class="black">Un mini-jeu, c’est est <b>une expérience ludique</b> intégrée à votre
                                    <b>site
                                        web</b>.
                                    <b>Rapide
                                        et simple</b>, il transforme la navigation en moment <b>interactif et
                                        mémorable</b>.
                                </p>
                            </div>
                            <div class="modal-container-text-paragraph">
                                <div class="text-paragraph-emojie"><img src="/svg/modalEmojie/target.svg"
                                        alt="Image représentant une cible">
                                    <h4 class="h3 black">Pourquoi ?</h4>
                                </div>
                                <p class="black">Avec un mini-jeu, votre site passe de fonctionnel à <b>captivant</b>.
                                    Il
                                    attire
                                    <b>l’attention</b>, <b>fidélise</b> vos visiteurs et crée un <b>lien</b> immédiat
                                    avec votre <b>univers</b>.
                                </p>
                            </div>
                            <div></div>
                        </div>
                        <div class="modal-container-info">
                            <div class="modal-container-text-paragraph">
                                <div class="text-paragraph-emojie"><img src="/svg/modalEmojie/rouage.svg"
                                        alt="Image représentant un rouage">
                                    <h4 class="h3 black">Support</h4>
                                </div>
                                <p class="black"><b>Numérique</b>, intégré à un site web</p>
                            </div>
                            <div class="modal-container-text-paragraph">
                                <div class="text-paragraph-emojie"><img src="/svg/modalEmojie/temps.svg"
                                        alt="Image représentant une horlange">
                                    <h4 class="h3 black">Durée</h4>
                                </div>
                                <p class="black"><b>5</b> à <b>20 minutes</b></p>
                            </div>
                            <div class="modal-container-text-paragraph">
                                <div class="text-paragraph-emojie"><img src="/svg/modalEmojie/guy.svg"
                                        alt="Image représentant une personne">
                                    <h4 class="h3 black">Nombre de participants</h4>
                                </div>
                                <p class="black">Jeu <b>individuel</b> ou <b>multijoueur</b></p>
                            </div>
                        </div>
                    </div>
                    <div class="aligne-btn-center">
                        <a href="#contactForm" class="text-typo  btn-project btn-white-background"
                            data-format="mini_jeu">
                            <span>Je crée mon mini-jeu web</span>
                            <div class="arrow-container black-arrow">
                                <img src="/svg/arrowB.svg" alt="fleche">
                            </div>
                        </a>
                    </div>
                </div>
            </div>
        </div>

        <div id="modal-histoire-interactive" class="modal" role="dialog" aria-modal="true"
            aria-labelledby="modal-histoire-interactive-title">
            <div class="modal-header">
                <div class="modal-header-null-object"></div>
                <h2 class="h1 black header-modal-tilte">
                    <div class="paterneTitleContainer"><span>Histoire interactive</span><span
                            class="paterneTitleContour">Histoire interactive</span></div>
                </h2><button class="btn-close" aria-label="Fermer">
                    <div class="close-line"></div>
                    <div class="close-line"></div>
                </button>
            </div>

            <div>
                <div class="modal-container modal-purple">
                    <h3 id="modal-histoire-interactive" class="h2 black sub-title-modal">Quel <span
                            class="highlight-no-annim purple white-border">chemin</span> prendrez-vous ?</h3>
                    <div class="modal-container-content">
                        <div class="modal-container-text">
                            <div class="modal-container-text-paragraph">
                                <div class="text-paragraph-emojie"><img src="/svg/modalEmojie/interogation.svg"
                                        alt="Image représentant un point d'interogation">
                                    <h4 class="h3 black">C’est quoi ?</h4>
                                </div>
                                <p class="black">Une histoire interactive, c’est <b>un récit narratif</b> où le lecteur
                                    devient
                                    acteur.
                                    Chaque décision qu’il prend <b>impacte</b> le déroulement, rendant chaque lecture
                                    <b>unique</b>.
                                </p>
                            </div>
                            <div class="modal-container-text-paragraph">
                                <div class="text-paragraph-emojie"><img src="/svg/modalEmojie/target.svg"
                                        alt="Image représentant une cible">
                                    <h4 class="h3 black">Pourquoi ?</h4>
                                </div>
                                <p class="black">À travers ses choix, le joueur développe <b>un attachement</b> au récit
                                    et à
                                    ses
                                    personnages. L’impact de ses actions lui permet de <b>s’identifier</b>,
                                    transformant
                                    l’expérience en moment <b>émotionnel</b> et <b>mémorable</b>.</p>
                            </div>
                            <div></div>
                        </div>
                        <div class="modal-container-info">
                            <div class="modal-container-text-paragraph">
                                <div class="text-paragraph-emojie"><img src="/svg/modalEmojie/rouage.svg"
                                        alt="Image représentant un rouage">
                                    <h4 class="h3 black">Support</h4>
                                </div>
                                <p class="black"><b>Numérique</b></p>
                            </div>
                            <div class="modal-container-text-paragraph">
                                <div class="text-paragraph-emojie"><img src="/svg/modalEmojie/temps.svg"
                                        alt="Image représentant une horlange">
                                    <h4 class="h3 black">Durée</h4>
                                </div>
                                <p class="black"><b>20 minutes</b> à <b>1 heure</b></p>
                            </div>
                            <div class="modal-container-text-paragraph">
                                <div class="text-paragraph-emojie"><img src="/svg/modalEmojie/guy.svg"
                                        alt="Image représentant une personne">
                                    <h4 class="h3 black">Nombre de participants</h4>
                                </div>
                                <p class="black"><b>Individuel</b></p>
                            </div>
                        </div>
                    </div>
                    <div class="aligne-btn-center">
                        <a href="#contactForm" class="text-typo  btn-project btn-white-background"
                            data-format="histoire_interactive">
                            <span> <span>J'écris mon histoire</span></span>
                            <div class="arrow-container black-arrow">
                                <img src="/svg/arrowB.svg" alt="fleche">
                            </div>
                        </a>
                    </div>
                </div>
            </div>
        </div>

        <div id="modal-geocaching" class="modal" role="dialog" aria-modal="true"
            aria-labelledby="modal-geocaching-title">
            <div class="modal-header">
                <div class="modal-header-null-object"></div>
                <h2 class="h1 black header-modal-tilte">
                    <div class="paterneTitleContainer"><span>Geocaching</span><span
                            class="paterneTitleContour">Geocaching</span></div>
                </h2><button class="btn-close" aria-label="Fermer">
                    <div class="close-line"></div>
                    <div class="close-line"></div>
                </button>
            </div>

            <div>
                <div class="modal-container modal-blue">

                    <h3 id="modal-geocaching" class="h2 black sub-title-modal">Où se cache <span
                            class="highlight-no-annim blue white-border"> le trésor ?</span></h3>
                    <div class="modal-container-content">
                        <div class="modal-container-text">
                            <div class="modal-container-text-paragraph">
                                <div class="text-paragraph-emojie"><img src="/svg/modalEmojie/interogation.svg"
                                        alt="Image représentant un point d'interogation">
                                    <h4 class="h3 black">C’est quoi ?</h4>
                                </div>
                                <p class="black">Le géocaching, c’est <b>une chasse au trésor</b> interactive où les
                                    participants
                                    suivent <b>des indices ou coordonnées GPS</b> pour retrouver des objets, des lieux
                                    ou des
                                    informations cachées.</p>
                            </div>
                            <div class="modal-container-text-paragraph">
                                <div class="text-paragraph-emojie"><img src="/svg/modalEmojie/target.svg"
                                        alt="Image représentant une cible">
                                    <h4 class="h3 black">Pourquoi ?</h4>
                                </div>
                                <p class="black">Ce format invite les joueurs à explorer <b>un espace réel</b> et à en
                                    <b>apprendre</b>
                                    davantage sur un lieu, une histoire ou un patrimoine, tout en vivant une aventure.
                                </p>
                            </div>
                            <div></div>
                        </div>
                        <div class="modal-container-info">
                            <div class="modal-container-text-paragraph">
                                <div class="text-paragraph-emojie"><img src="/svg/modalEmojie/rouage.svg"
                                        alt="Image représentant un rouage">
                                    <h4 class="h3 black">Support</h4>
                                </div>
                                <p class="black"><b>Hybride</b> (application mobile + exploration réelle)</p>
                            </div>
                            <div class="modal-container-text-paragraph">
                                <div class="text-paragraph-emojie"><img src="/svg/modalEmojie/temps.svg"
                                        alt="Image représentant une horlange">
                                    <h4 class="h3 black">Durée</h4>
                                </div>
                                <p class="black"><b>30 minutes</b> à <b>2 heures</b></p>
                            </div>
                            <div class="modal-container-text-paragraph">
                                <div class="text-paragraph-emojie"><img src="/svg/modalEmojie/guy.svg"
                                        alt="Image représentant une personne">
                                    <h4 class="h3 black">Nombre de participants</h4>
                                </div>
                                <p class="black"><b>Un seul téléphone</b> suffit, activité réalisable <b>seul</b> ou en
                                    <b>groupe</b>
                                </p>
                            </div>
                        </div>
                    </div>
                    <div class="aligne-btn-center">
                        <a href="#contactForm" class="text-typo  btn-project btn-white-background"
                            data-format="geocaching">
                            <span>Je lance mon géocaching</span>
                            <div class="arrow-container black-arrow">
                                <img src="/svg/arrowB.svg" alt="fleche">
                            </div>
                        </a>
                    </div>
                </div>
            </div>
        </div>

  

    <script src="/js/modal.js" defer></script>
    <script src="/js/faq.js" defer></script>

</BaseLayout>
