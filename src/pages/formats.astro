---
/**
 * pages/formats.astro — Nos formats
 */
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Nos formats"
  description="Découvrez tous les formats d'expériences ludiques et interactives proposés par Loooper! : quiz, escape game, jeux de rôle, ateliers créatifs et bien plus encore."
  ogImage="https://loooper.fr/img/ico/FORMATS.png"
  ogUrl="https://loooper.fr/formats"
  currentPage="formats"
>
<main>
        <section class="mainPageTitle mainPageTitleOrange">
            <h1 class="h1 container-width white-border black">Loooper!, c’est des formats qui s’adaptent pour devenir
                <span> </span>
                <div class="paterneTitleContainer"><span class="paterneTitle paterneTitlePurple">le </span><span
                        class="paterneTitleContour">le </span></div>
                <div class="paterneTitleContainer"><span class="paterneTitle paterneTitlePurple">vôtre !</span><span
                        class="paterneTitleContour">vôtre !</span></div>
            </h1>
        </section>
        <div class="container-width ariane-net h3"><a href="/">Accueil </a>
            <p class="h3">></p> <a href="/formats/"
                class="end-chield highlight-no-annim purple black-border-small">Nos formats</a>
        </div>


        <div id="foot-form1" class="container-width">
            <div class="large-spacing"></div>
            <section class=" text-basical-container">
                <article class="text-basical-container-text-long">
                    <div>
                        <h2 class="h2 black white-border">Découvrez notre univers et nos valeurs !
                        </h2>
                        <div class="small-medium-spacing"></div>
                        <p><b>Loooper!</b> transforme <b>vos idées</b> en <b class="highlight purple">formats
                                interactifs sur
                                mesure.</b></p>
                        <p> Chaque projet devient <b>unique</b>, pensé pour s’adapter à votre image… et captiver votre
                            public.</p>
                        <p>La <b class="highlight blue">ludification</b> est notre moteur : <b>apprendre, découvrir,
                                s’amuser autrement</b>.</p>
                        <p>Pour vous donner un aperçu de nos possibilités, explorez tous <b>les formats</b> que nous
                            pouvons développer <b>ensemble</b>.</p>
                        <p>Avec nous, la seule limite… c’est votre <b class="highlight orange">imagination !</b></p>
                    </div>
                </article>
                <article class="text-basical-container-emojie">
                    <div class="emojie-img-line-container-besoin-child formatType">
                        <div class="emojie-img-line-besoin-child star">
                            <img src="/svg/starBecolorType2.svg" alt="Image representant des étoile">
                        </div>
                        <img class="emojie-img-line-besoin-child" src="/svg/handStar.svg"
                            alt="Image representant des connection entre personne">
                        <div class="emojie-img-line-besoin-child star2">
                            <img src="/svg/starBecolorType1.svg" alt="Image representant des étoile">
                        </div>
                    </div>

                </article>
            </section>

            <div class="large-spacing"></div>

            <h2 id="foot-form2" class="h2 black white-border">Des formats personnalisables avec leurs atouts</h2>
            <div class="small-medium-spacing"></div>
            <div class="card-info-wrap">
                <article class="card-info-container card-info-container-orange">
                    <img src="/img/card/zemblanite.jpg" alt="Image représentant un jeu video">
                    <div class="card-info-container-text">
                        <div class="card-info-container-text-alignement">
                            <h3 class="h3 black white-border highlight-no-annim orange">Jeu vidéo</h3>
                            <ul>
                                <li class="text-typo black">Un format numérique immersif</li>
                                <li class="text-typo black">Accessible à tous, partout</li>
                            </ul>
                        </div>
                        <div class="card-info-container-text-center-btn"> <button data-modal="modal-jeu-video"
                                aria-haspopup="dialog" class="text-typo btn-project btn-modal btn-white-background"
                                aria-label="En savoir plus sur les jeux video">
                                <span>En savoir plus</span> </button></div>
                    </div>
                </article>

                <article class="card-info-container card-info-container-purple">
                    <img src="/img/card/quiz.jpg" alt="Image représentant un quiz">
                    <div class="card-info-container-text">
                        <div class="card-info-container-text-alignement">
                            <h3 class="h3 black white-border highlight-no-annim purple">Quiz</h3>
                            <ul>
                                <li class="text-typo black">Un jeu collectif qui crée du lien</li>
                                <li class="text-typo black">Se défier et apprendre autrement</li>
                            </ul>
                        </div>
                        <div class="card-info-container-text-center-btn"> <button data-modal="modal-quiz"
                                aria-haspopup="dialog" class="text-typo btn-project btn-modal btn-white-background"
                                aria-label="En savoir plus sur le quiz">
                                <span>En savoir plus</span> </button></div>
                    </div>
                </article>

                <article class="card-info-container card-info-container-blue">
                    <img src="/img/card/histoire.jpg" alt="Image représentant une histoire">
                    <div class="card-info-container-text">
                        <div class="card-info-container-text-alignement">
                            <h3 class="h3 black white-border highlight-no-annim blue">Histoire interactive</h3>
                            <ul>
                                <li class="text-typo black">Une histoire immersive</li>
                                <li class="text-typo black">Chaque choix transforme le récit</li>
                            </ul>
                        </div>
                        <div class="card-info-container-text-center-btn"> <button
                                data-modal="modal-histoire-interactive" aria-haspopup="dialog"
                                class="text-typo btn-project btn-modal btn-white-background"
                                aria-label="En savoir plus sur les Histoire interactive">
                                <span>En savoir plus</span> </button></div>
                    </div>
                </article>

                <article class="card-info-container card-info-container-orange">
                    <img src="/img/card/jeux.jpg" alt="Image représentant un Mini-jeu sur site web">
                    <div class="card-info-container-text">
                        <div class="card-info-container-text-alignement">
                            <h3 class="h3 black white-border highlight-no-annim orange">Mini-jeu sur site web</h3>
                            <ul>
                                <li class="text-typo black">Interaction rapide et fun</li>
                                <li class="text-typo black">Engagez vos visiteurs en s’amusant</li>
                            </ul>
                        </div>
                        <div class="card-info-container-text-center-btn"> <button data-modal="modal-mini-jeu"
                                aria-haspopup="dialog" class="text-typo btn-project btn-modal btn-white-background"
                                aria-label="En savoir plus sur les Mini-jeu">
                                <span>En savoir plus</span> </button></div>
                    </div>
                </article>

                <article class="card-info-container card-info-container-purple">
                    <img src="/img/card/escapeGame.jpg" alt="Image représentant un Escape game">
                    <div class="card-info-container-text">
                        <div class="card-info-container-text-alignement">
                            <h3 class="h3 black white-border highlight-no-annim purple">Escape game</h3>
                            <ul>
                                <li class="text-typo black">S’entraider pour réussir</li>
                                <li class="text-typo black">S’immerger dans un univers captivant</li>
                            </ul>
                        </div>
                        <div class="card-info-container-text-center-btn"> <button data-modal="modal-escape-game"
                                aria-haspopup="dialog" class="text-typo btn-project btn-modal btn-white-background"
                                aria-label="En savoir plus sur les Escape game">
                                <span>En savoir plus</span> </button></div>
                    </div>
                </article>

                <article class="card-info-container card-info-container-blue">
                    <img src="/img/card/jeuxDeSociéter.jpg" alt="Image représentant un Jeu de société">
                    <div class="card-info-container-text">
                        <div class="card-info-container-text-alignement">
                            <h3 class="h3 black white-border highlight-no-annim blue">Jeu de société</h3>
                            <ul>
                                <li class="text-typo black">Alliés ou Adversaires ?</li>
                                <li class="text-typo black">Apprendre en s’amusant</li>
                            </ul>
                        </div>
                        <div class="card-info-container-text-center-btn"> <button data-modal="modal-jeu-societe"
                                aria-haspopup="dialog" class="text-typo btn-project btn-modal btn-white-background"
                                aria-label="En savoir plus sur les Jeu de société">
                                <span>En savoir plus</span> </button></div>
                    </div>
                </article>

                <article class="card-info-container card-info-container-orange">
                    <img src="/img/card/geoCaching.jpg" alt="Image représentant du Géocaching">
                    <div class="card-info-container-text">
                        <div class="card-info-container-text-alignement">
                            <h3 class="h3 black white-border highlight-no-annim orange">Géocaching</h3>
                            <ul>
                                <li class="text-typo black">Apprendre en explorant un espace</li>
                                <li class="text-typo black">Chasse au trésor interactive</li>
                            </ul>
                        </div>
                        <div class="card-info-container-text-center-btn"> <button data-modal="modal-geocaching"
                                aria-haspopup="dialog" class="text-typo btn-project btn-modal btn-white-background"
                                aria-label="En savoir plus sur le Géocaching">
                                <span>En savoir plus</span> </button></div>
                    </div>
                </article>

                <article class="card-info-container card-info-container-purple">
                    <img src="/img/card/interogation.jpg" alt="Image représentant un point d'interogation">
                    <div class="card-info-container-text card-info-container-text-interogation">
                        <div class="card-info-container-text-alignement">
                            <h3 class="h3 black white-border highlight-no-annim purple">Une autre idée ?</h3>
                            <ul>
                                <li class="text-typo">Discutons-en pour trouver ce qui vous conviendrait le mieux
                                    !</li>
                            </ul>
                        </div>
                        <a href="#contactForm" class="text-typo  btn-project">
                            <span>Parler de mon idée</span>
                            <div class="arrow-container">
                                <img src="/svg/arrowW.svg" alt="fleche">
                            </div>
                        </a>
                    </div>
                </article>
            </div>
        </div>

        <div id="modal-jeu-video" class="modal" role="dialog" aria-modal="true" aria-labelledby="modal-jeu-video-title">
            <div class="modal-header">
                <div class="modal-header-null-object"></div>
                <h2 class="h1 black header-modal-tilte">
                    <div class="paterneTitleContainer"><span>Jeu vidéo</span><span class="paterneTitleContour">Jeu
                            vidéo</span></div>
                </h2><button class="btn-close" aria-label="Fermer">
                    <div class="close-line"></div>
                    <div class="close-line"></div>
                </button>
            </div>

            <div>
                <div class="modal-container modal-orange">

                    <h3 id="modal-jeu-video-title" class="h2 black sub-title-modal">Et si votre idée devenait <span
                            class="highlight-no-annim orange white-border">un monde à explorer ?</span></h3>

                    <div class="modal-container-content">
                        <div class="modal-container-text">
                            <div class="modal-container-text-paragraph">
                                <div class="text-paragraph-emojie"><img src="/svg/modalEmojie/interogation.svg"
                                        alt="Image représentant un point d'interogation">
                                    <h4 class="h3 black">C’est quoi ?</h4>
                                </div>
                                <p class="black">Le jeu vidéo, c’est <b>une aventure interactive</b> qui prend vie sur
                                    ordinateur, console ou mobile. Avec ses graphismes et ses mécaniques, ce format crée
                                    <b>une expérience captivante et
                                        inoubliable</b>.
                                </p>
                            </div>
                            <div class="modal-container-text-paragraph">
                                <div class="text-paragraph-emojie"><img src="/svg/modalEmojie/target.svg"
                                        alt="Image représentant une cible">
                                    <h4 class="h3 black">Pourquoi ?</h4>
                                </div>
                                <p class="black">Idéal pour <b>apprendre, sensibiliser ou faire découvrir autrement</b>,
                                    le jeu
                                    vidéo
                                    plonge
                                    vos
                                    participants
                                    dans un univers unique <b>sur mesure</b> qui met en avant <b>vos contenus et vos
                                        valeurs</b>. 100
                                    %
                                    numérique, il
                                    peut toucher <b>un large public</b> et intégrer <b>des mécaniques pédagogiques</b>.
                            </div>
                        </div>
                        <div class="modal-container-info">
                            <div class="modal-container-text-paragraph">
                                <div class="text-paragraph-emojie"><img src="/svg/modalEmojie/rouage.svg"
                                        alt="Image représentant un rouage">
                                    <h4 class="h3 black">Support</h4>
                                </div>
                                <p class="black"><b>Numérique </b> et peut être accompagné d’un kit pédagogique physique
                                </p>
                            </div>
                            <div class="modal-container-text-paragraph">
                                <div class="text-paragraph-emojie"><img src="/svg/modalEmojie/temps.svg"
                                        alt="Image représentant une horlange">
                                    <h4 class="h3 black">Durée</h4>
                                </div>
                                <p class="black">De <b>10 minutes</b> à <b>1 heure</b></p>
                            </div>
                            <div class="modal-container-text-paragraph">
                                <div class="text-paragraph-emojie"><img src="/svg/modalEmojie/guy.svg"
                                        alt="Image représentant une personne">
                                    <h4 class="h3 black">Nombre de participants</h4>
                                </div>
                                <p class="black">Jeu <b>individuel</b> ou <b>multijoueur</b></p>
                            </div>
                        </div>
                    </div>
                    <div class="aligne-btn-center">
                        <a href="#contactForm" class="text-typo  btn-project btn-white-background"
                            data-format="jeu_video">
                            <span>Je transforme mon idée en jeu</span>
                            <div class="arrow-container black-arrow">
                                <img src="/svg/arrowB.svg" alt="fleche">
                            </div>
                        </a>
                    </div>
                </div>
            </div>
        </div>



        <div id="modal-quiz" class="modal" role="dialog" aria-modal="true" aria-labelledby="modal-quiz-title">
            <div class="modal-header">
                <div class="modal-header-null-object"></div>
                <h2 class="h1 black header-modal-tilte">
                    <div class="paterneTitleContainer"><span>Quiz</span><span class="paterneTitleContour">Quiz</span>
                    </div>
                </h2><button class="btn-close" aria-label="Fermer">
                    <div class="close-line"></div>
                    <div class="close-line"></div>
                </button>
            </div>


            <div>
                <div class="modal-container modal-purple">
                    <h3 id="modal-quiz" class="h2 black sub-title-modal">Qui remportera <span
                            class="highlight-no-annim purple white-border">la manche ?</span></h3>
                    <div class="modal-container-content">
                        <div class="modal-container-text">
                            <div class="modal-container-text-paragraph">
                                <div class="text-paragraph-emojie"><img src="/svg/modalEmojie/interogation.svg"
                                        alt="Image représentant un point d'interogation">
                                    <h4 class="h3 black">C’est quoi ?</h4>
                                </div>
                                <p class="black">Le quiz, c’est LE jeu universel pour tester <b>ses connaissances en
                                        s’amusant</b>.
                                    Défiez-vous autour d’une série <b>de questions personnalisées</b> sur le sujet de
                                    votre
                                    choix.
                                    <b>Scores, défis, classements…</b> les mécaniques s’adaptent pour <b>captiver</b> et
                                    <b>faire vibrer</b>
                                    votre
                                    public.
                                </p>
                            </div>
                            <div class="modal-container-text-paragraph">
                                <div class="text-paragraph-emojie"><img src="/svg/modalEmojie/target.svg"
                                        alt="Image représentant une cible">
                                    <h4 class="h3 black">Pourquoi ?</h4>
                                </div>
                                <p class="black">Plus qu’un simple jeu, le quiz est <b>une activité fédératrice</b> : il
                                    renforce
                                    <b>la
                                        complicité</b> des participants, encourage <b>la réflexion</b> et permet
                                    <b>d’apprendre
                                        différemment</b>.
                                    Un
                                    outil parfait pour <b>créer du lien</b>, <b>transmettre</b> vos messages et
                                    valoriser <b>vos
                                        contenus.</b>
                                </p>
                            </div>
                            <div></div>
                        </div>
                        <div class="modal-container-info">
                            <div class="modal-container-text-paragraph">
                                <div class="text-paragraph-emojie"><img src="/svg/modalEmojie/rouage.svg"
                                        alt="Image représentant un rouage">
                                    <h4 class="h3 black">Support</h4>
                                </div>
                                <p class="black"><b>Numérique</b> ou <b>hybride</b> avec participants en présentiel</p>
                            </div>
                            <div class="modal-container-text-paragraph">
                                <div class="text-paragraph-emojie"><img src="/svg/modalEmojie/temps.svg"
                                        alt="Image représentant une horlange">
                                    <h4 class="h3 black">Durée</h4>
                                </div>
                                <p class="black"><b>10 à 30 minutes</b></p>
                            </div>
                            <div class="modal-container-text-paragraph">
                                <div class="text-paragraph-emojie"><img src="/svg/modalEmojie/guy.svg"
                                        alt="Image représentant une personne">
                                    <h4 class="h3 black">Nombre de participants</h4>
                                </div>
                                <p class="black"><b>Illimité</b> en digital, <b>2 à 50</b> en présentiel.</p>
                            </div>
                        </div>
                    </div>
                    <div class="aligne-btn-center">
                        <a href="#contactForm" class="text-typo  btn-project btn-white-background" data-format="quiz">
                            <span>Je lance mon quiz</span>
                            <div class="arrow-container black-arrow">
                                <img src="/svg/arrowB.svg" alt="fleche">
                            </div>
                        </a>
                    </div>
                </div>
            </div>
        </div>




        <div id="modal-histoire-interactive" class="modal" role="dialog" aria-modal="true"
            aria-labelledby="modal-histoire-interactive-title">
            <div class="modal-header">
                <div class="modal-header-null-object"></div>
                <h2 class="h1 black header-modal-tilte">
                    <div class="paterneTitleContainer"><span>Histoire interactive</span><span
                            class="paterneTitleContour">Histoire interactive</span></div>
                </h2><button class="btn-close" aria-label="Fermer">
                    <div class="close-line"></div>
                    <div class="close-line"></div>
                </button>
            </div>

            <div>
                <div class="modal-container modal-blue">
                    <h3 id="modal-histoire-interactive" class="h2 black sub-title-modal">Quel <span
                            class="highlight-no-annim blue white-border">chemin</span> prendrez-vous ?</h3>
                    <div class="modal-container-content">
                        <div class="modal-container-text">
                            <div class="modal-container-text-paragraph">
                                <div class="text-paragraph-emojie"><img src="/svg/modalEmojie/interogation.svg"
                                        alt="Image représentant un point d'interogation">
                                    <h4 class="h3 black">C’est quoi ?</h4>
                                </div>
                                <p class="black">Une histoire interactive, c’est <b>un récit narratif</b> où le lecteur
                                    devient
                                    acteur.
                                    Chaque décision qu’il prend <b>impacte</b> le déroulement, rendant chaque lecture
                                    <b>unique</b>.
                                </p>
                            </div>
                            <div class="modal-container-text-paragraph">
                                <div class="text-paragraph-emojie"><img src="/svg/modalEmojie/target.svg"
                                        alt="Image représentant une cible">
                                    <h4 class="h3 black">Pourquoi ?</h4>
                                </div>
                                <p class="black">À travers ses choix, le joueur développe <b>un attachement</b> au récit
                                    et à
                                    ses
                                    personnages. L’impact de ses actions lui permet de <b>s’identifier</b>,
                                    transformant
                                    l’expérience en moment <b>émotionnel</b> et <b>mémorable</b>.</p>
                            </div>
                            <div></div>
                        </div>
                        <div class="modal-container-info">
                            <div class="modal-container-text-paragraph">
                                <div class="text-paragraph-emojie"><img src="/svg/modalEmojie/rouage.svg"
                                        alt="Image représentant un rouage">
                                    <h4 class="h3 black">Support</h4>
                                </div>
                                <p class="black"><b>Numérique</b></p>
                            </div>
                            <div class="modal-container-text-paragraph">
                                <div class="text-paragraph-emojie"><img src="/svg/modalEmojie/temps.svg"
                                        alt="Image représentant une horlange">
                                    <h4 class="h3 black">Durée</h4>
                                </div>
                                <p class="black"><b>20 minutes</b> à <b>1 heure</b></p>
                            </div>
                            <div class="modal-container-text-paragraph">
                                <div class="text-paragraph-emojie"><img src="/svg/modalEmojie/guy.svg"
                                        alt="Image représentant une personne">
                                    <h4 class="h3 black">Nombre de participants</h4>
                                </div>
                                <p class="black"><b>Individuel</b></p>
                            </div>
                        </div>
                    </div>
                    <div class="aligne-btn-center">
                        <a href="#contactForm" class="text-typo  btn-project btn-white-background"
                            data-format="histoire_interactive">
                            <span> <span>J'écris mon histoire</span></span>
                            <div class="arrow-container black-arrow">
                                <img src="/svg/arrowB.svg" alt="fleche">
                            </div>
                        </a>
                    </div>
                </div>
            </div>
        </div>




        <div id="modal-mini-jeu" class="modal" role="dialog" aria-modal="true" aria-labelledby="modal-mini-jeu-title">
            <div class="modal-header">
                <div class="modal-header-null-object"></div>
                <h2 class="h1 black header-modal-tilte">
                    <div class="paterneTitleContainer"><span>Mini-jeu</span><span
                            class="paterneTitleContour">Mini-jeu</span></div>
                </h2><button class="btn-close" aria-label="Fermer">
                    <div class="close-line"></div>
                    <div class="close-line"></div>
                </button>
            </div>

            <div>
                <div class="modal-container modal-orange">

                    <h3 id="modal-mini-jeu-interactive" class="h2 black sub-title-modal">Transformez une visite en <span
                            class="highlight-no-annim orange white-border">aventure !</span></h3>
                    <div class="modal-container-content">
                        <div class="modal-container-text">
                            <div class="modal-container-text-paragraph">
                                <div class="text-paragraph-emojie"><img src="/svg/modalEmojie/interogation.svg"
                                        alt="Image représentant un point d'interogation">
                                    <h4 class="h3 black">C’est quoi ?</h4>
                                </div>
                                <p class="black">Un mini-jeu, c’est est <b>une expérience ludique</b> intégrée à votre
                                    <b>site
                                        web</b>.
                                    <b>Rapide
                                        et simple</b>, il transforme la navigation en moment <b>interactif et
                                        mémorable</b>.
                                </p>
                            </div>
                            <div class="modal-container-text-paragraph">
                                <div class="text-paragraph-emojie"><img src="/svg/modalEmojie/target.svg"
                                        alt="Image représentant une cible">
                                    <h4 class="h3 black">Pourquoi ?</h4>
                                </div>
                                <p class="black">Avec un mini-jeu, votre site passe de fonctionnel à <b>captivant</b>.
                                    Il
                                    attire
                                    <b>l’attention</b>, <b>fidélise</b> vos visiteurs et crée un <b>lien</b> immédiat
                                    avec votre <b>univers</b>.
                                </p>
                            </div>
                            <div></div>
                        </div>
                        <div class="modal-container-info">
