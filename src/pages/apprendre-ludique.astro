---
/**
 * pages/apprendre-ludique.astro — Apprendre avec le ludique
 */
import BaseLayout from '../layouts/BaseLayout.astro';
import Quiz from "../components/Modal/Quiz.astro";
import JeuSociete from "../components/Modal/JeuSociete.astro";
import GeoCaching from "../components/Modal/GeoCaching.astro";
---

<BaseLayout
  title="Apprendre avec le ludique"
  description="Découvrez comment apprendre autrement grâce à la pédagogie ludique : comprendre en s'amusant et retenir durablement."
  ogUrl="https://loooper.fr/apprendre-ludique"
  currentPage="apprendre-ludique"
><section class="mainPageTitle mainPageTitleBlue">
            <h1 class="h1 container-width white-border black">Loooper! c’est apprendre avec <span> </span>
                <div class="paterneTitleContainer"><span class="paterneTitle paterneTitleOrange">le </span><span
                        class="paterneTitleContour">le </span></div>
                <div class="paterneTitleContainer"><span class="paterneTitle paterneTitleOrange">ludique </span><span
                        class="paterneTitleContour">ludique </span></div>
                <div class="paterneTitleContainer"><span class="paterneTitle paterneTitleOrange">et</span><span
                        class="paterneTitleContour">et</span></div>
                <div class="paterneTitleContainer"><span class="paterneTitle paterneTitleOrange">l’interactif
                        !</span><span class="paterneTitleContour">l’interactif !</span></div>
            </h1>
        </section>
        <div class="container-width ariane-net h3"><a href="/">Accueil </a>
            <p class="h3">></p> <a href="/besoins/">Vos besoins</a>
            <p class="h3">></p> <a href="/apprendre-ludique/"
                class="end-chield highlight-no-annim orange black-border-small"> Apprendre avec le ludique </a>
        </div>

        <div class="large-spacing"></div>


        <section class="container-width text-basical-container">
            <article class="text-basical-container-text-long">
                <div>
                    <h2 class="h2 black white-border">Apprendre en s’amusant ?
                    </h2>
                    <div class="small-medium-spacing"></div>

                    <p>
                        Chez <b>Loooper!</b>, nous sommes persuadés d'une chose : <b
                            class="highlight orange">l'apprentissage peut (et doit) être amusant</b>. Grâce à la
                        <b>gamification</b>, nous transformons des contenus parfois complexes en expériences <b
                            class="highlight purple">vivantes, engageantes et mémorables</b>. Avec une approche <b
                            class="highlight blue">ludique et interactive</b>, chacun <b>s'implique activement</b> dans
                        son processus d'apprentissage. Résultat : on développe sa <b>curiosité</b>, on retient mieux les
                        notions difficiles et surtout… on prend <b>plaisir à apprendre</b>.
                    </p>
                </div>
            </article>
            <article class="text-basical-container-emojie">
                <div class="emojie-img-line-container-besoin-child">
                    <div class="emojie-img-line-besoin-child star">
                        <img src="/svg/besoin/starPurpleType2.svg" alt="Image representant des étoiles">
                    </div>
                    <img class="emojie-img-line-besoin-child" src="/svg/besoin/idea.svg"
                        alt="Image representant une empoule">
                    <div class="emojie-img-line-besoin-child star2">
                        <img src="/svg/besoin/starPurpleType1.svg" alt="Image representant des étoiles">
                    </div>
                </div>

            </article>
        </section>

        <div class="large-spacing"></div>

        <div class="backgroundBrushType1">
            <section class="container-width long-card-container">
                <h2 class="h2 black white-border">Les formats qui apportent une pédagogie ludique</h2>
                <div class="small-medium-spacing"></div>
                <div class="long-card-wrapper">
                    <article class="long-card long-card-orange">
                        <img src="/img/long-card/cart-cartel.jpg" alt="image representative d'un quiz">
                        <div class="long-card-text-content">
                            <div>
                                <h3 class="h2 black white-border highlight-no-annim orange"
                                    id="book-page-part-1-container-title">
                                    Quiz</h3>
                            </div>
                            <p class="black">Testez vos <b>connaissances</b>, enrichissez-les avec de <b>nouveaux
                                    savoirs</b> et stimulez la <b>compétition bienveillante</b> entre participants.</p>
                            <button data-modal="modal-quiz" aria-haspopup="dialog"
                                class="text-typo btn-project btn-modal btn-white-background"
                                aria-label="En savoir plus sur le quiz">
                                <span>En savoir plus</span> </button>
                        </div>
                    </article>

                    <article class="long-card long-card-purple">
                        <img src="/img/long-card/geocaching.jpg" alt="image representative du Geocaching">
                        <div class="long-card-text-content">
                            <div>
                                <h3 class="h2 black white-border highlight-no-annim purple"
                                    id="book-page-part-1-container-title">
                                    Géocaching</h3>
                            </div>
                            <p class="black">Partez à la <b>découverte d’un lieu</b>, résolvez des <b>énigmes</b> sur le
                                terrain et plongez dans un univers <b>d’apprentissage</b>.

                            </p>
                            <button data-modal="modal-geocaching" aria-haspopup="dialog"
                                class="text-typo btn-project btn-modal btn-white-background"
                                aria-label="En savoir plus sur le Géocaching">
                                <span>En savoir plus</span> </button>

                    </article>

                    <article class="long-card long-card-blue">
                        <img src="/img/long-card/biker.jpg" alt="image representative d'une jeu de société">
                        <div class="long-card-text-content">
                            <div>
                                <h3 class="h2 black white-border highlight-no-annim blue"
                                    id="book-page-part-1-container-title">
                                    Jeu de société</h3>
                            </div>
                            <p class="black">Utilisez des <b>mécaniques ludiques</b> pour comprendre des contenus,
                                favorisez la <b>réflexion</b>, et engagez la discussion sur ce qui est appris.</p>
                            <button data-modal="modal-jeu-societe" aria-haspopup="dialog"
                                class="text-typo btn-project btn-modal btn-white-background"
                                aria-label="En savoir plus sur les Jeu de société">
                                <span>En savoir plus</span> </button>
                        </div>
                    </article>
                </div>
                <div class="small-medium-spacing"></div>
                <a href="/formats/" class="text-typo btn-project btn-white-background">
                    <span>Découvrir nos autres formats</span>
                </a>
            </section>
        </div>

        <div class="large-spacing"></div>

        <div class="zoom-container-center">
            <div class="zoom-container background-interogation background-interogation-purple">
                <section class="container-width">
                    <h2 class="h2 black">Des questions sur l'apprentissage par le jeu ?
                    </h2>
                    <div class="small-medium-spacing"></div>
                    <div class="wrapper-faq-container-info">
                        <div class="wrapper-faq-container-info-row">
                            <article class="faq-container-info">
                                <div class="faq-header">
                                    <div>
                                        <div class="faq-arrow faq-arrow-orange">
                                            <div class="faq-arrow-1"></div>
                                            <div class="faq-arrow-2"></div>
                                        </div>
                                    </div>
                                    <h3 class="h3 black">À qui s’adresse l’apprentissage par le jeu ?</h3>
                                </div>
                                <p class="black">
                                    <b>À tout le monde !</b> Enfants, étudiants, enseignants, entreprises, associations…
                                    Nos
                                    expériences interactives sont conçues pour convenir à <b>tous les types de
                                        public et à toutes les situations.</b>
                                </p>
                            </article>

                            <article class="faq-container-info">
                                <div class="faq-header">
                                    <div>
                                        <div class="faq-arrow faq-arrow-purple">
                                            <div class="faq-arrow-1"></div>
                                            <div class="faq-arrow-2"></div>
                                        </div>
                                    </div>
                                    <h3 class="h3 black">
                                        Les expériences sont-elles forcément numériques ?</h3>
                                </div>
                                <p class="black">
                                    Pas du tout. Nous créons aussi bien des expériences <b>digitales que réelles</b> :
                                    <a class="link-underline-black" href="/formats/">jeux de société, quiz en direct,
                                        géocaching…</a> L’important est de choisir le format qui correspond le mieux à
                                    <b>vos ressources et à vos publics</b>.
                                </p>
                            </article>
                        </div>
                        <div class="wrapper-faq-container-info-row">
                            <article class="faq-container-info">
                                <div class="faq-header">
                                    <div>
                                        <div class="faq-arrow faq-arrow-blue">
                                            <div class="faq-arrow-1"></div>
                                            <div class="faq-arrow-2"></div>
                                        </div>
                                    </div>
                                    <h3 class="h3 black">
                                        Peut-on adapter un jeu pédagogique
                                        à un domaine spécifique ?</h3>
                                </div>
                                <p class="black">
                                    Absolument. Chez <b>Loooper!</b>, chaque projet est conçu <b>sur mesure</b> pour
                                    répondre à <a class="link-underline-black" href="/besoins/">vos
                                        besoins et à vos objectifs</a>.
                                </p>
                            </article>

                            <article class="faq-container-info">
                                <div class="faq-header">
                                    <div>
                                        <div class="faq-arrow faq-arrow-orange">
                                            <div class="faq-arrow-1"></div>
                                            <div class="faq-arrow-2"></div>
                                        </div>
                                    </div>
                                    <h3 class="h3 black">Peut-on organiser un serious game
                                        pour un grand groupe ?</h3>
                                </div>
                                <p class="black">
                                    Oui ! Les formats de pédagogie ludique s'adaptent aussi bien à <b>de petits
                                        groupes</b>
                                    qu'à <b>des événements de grande ampleur</b>. Cela peut prendre la forme de <a
                                        class="link-underline-black" href="/formats/">quiz collectifs, d'ateliers
                                        interactifs ou d'expériences immersives en plein air</a>, <b>tout</b> est
                                    possible.
                                </p>
                            </article>
                        </div>
                    </div>
                </section>
            </div>
        </div>


    <Quiz />
    <JeuSociete />
    <GeoCaching />

    <script src="/js/modal.js" defer></script>
    <script src="/js/faq.js" defer></script>


</BaseLayout>
