---
/**
 * pages/contact.astro — Page de contact
 * Centralise le formulaire de contact, précédemment répété sur plusieurs pages.
 */
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Contact"
  description="Contactez Loooper! pour discuter de votre projet de gamification ou d'expérience interactive sur mesure. Notre équipe vous répond rapidement."
  ogUrl="https://loooper.fr/contact"
  currentPage="contact"
>
  <section class="contact-page">
    <div class="contact-page-inner">
      <h1 class="contact-page-title">Parlons de votre projet</h1>
      <p class="contact-page-subtitle">
        Vous avez un projet en tête&nbsp;? Remplissez ce formulaire et nous vous recontactons sous 48h.
      </p>

      <!--
        Formulaire de contact
        (Remplacez l'action par l'URL de votre fonction Netlify ou autre backend)
      -->
      <form
        class="contact-form"
        name="contact"
        method="POST"
        action="/netlify/functions/contact"
        data-netlify="true"
        netlify-honeypot="bot-field"
      >
        <!-- Honeypot anti-spam -->
        <p class="visually-hidden">
          <label>Ne pas remplir : <input name="bot-field" /></label>
        </p>

        <div class="form-group">
          <label for="nom">Nom / Prénom *</label>
          <input type="text" id="nom" name="nom" required placeholder="Jean Dupont" />
        </div>

        <div class="form-group">
          <label for="email">Email *</label>
          <input type="email" id="email" name="email" required placeholder="jean@exemple.fr" />
        </div>

        <div class="form-group">
          <label for="organisation">Organisation</label>
          <input type="text" id="organisation" name="organisation" placeholder="Nom de votre entreprise / association" />
        </div>

        <div class="form-group">
          <label for="sujet">Sujet *</label>
          <select id="sujet" name="sujet" required>
            <option value="" disabled selected>Choisissez un sujet</option>
            <option value="devis">Demande de devis</option>
            <option value="renseignement">Renseignement</option>
            <option value="partenariat">Partenariat</option>
            <option value="autre">Autre</option>
          </select>
        </div>

        <div class="form-group">
          <label for="message">Message *</label>
          <textarea id="message" name="message" required rows="6" placeholder="Décrivez votre projet ou votre question…"></textarea>
        </div>

        <!-- RGPD -->
        <div class="form-group form-group--checkbox">
          <input type="checkbox" id="rgpd" name="rgpd" required />
          <label for="rgpd">
            J'accepte que mes données soient traitées conformément à la
            <a href="/mentions-legales" target="_blank">politique de confidentialité</a> de Loooper!
          </label>
        </div>

        <button type="submit" class="btn btn-primary">Envoyer le message</button>
      </form>
    </div>
  </section>
</BaseLayout>
