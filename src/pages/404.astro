---
/**
 * pages/404.astro — Page d'erreur 404
 */
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Page introuvable"
  description="Cette page n'existe pas ou a été déplacée."
  noIndex={true}
>
  <!--
    Copiez ici le contenu de 404.html (hors head / header / footer)
    ou personnalisez directement :
  -->
  <section style="padding: 6rem 2rem; text-align: center; font-family: sans-serif;">
    <h1 style="font-size: 6rem; margin: 0;">404</h1>
    <p style="font-size: 1.5rem;">Oops ! Cette page est introuvable.</p>
    <a href="/" style="display: inline-block; margin-top: 2rem; padding: 1rem 2rem; background: #3C61F5; color: white; border-radius: 8px; text-decoration: none;">
      Retour à l'accueil
    </a>
  </section>
</BaseLayout>
