---
/**
 * pages/404.astro — Page d'erreur 404
 */
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="Page introuvable"
  description="Cette page n'existe pas ou a été déplacée."
  noIndex={true}
>
  <div class="container-404">
    <div class="backgroundBrushType1">
      <div class="medium-large-spacing"></div>
      <section class="center-404">
        <div class="small-spacing"></div>
        <h1
          class="h1 black paterneTitleContour"
          style="position: relative; user-select: all;"
        >
          Erreur
        </h1>
        <h1 class="h1 white-border black">
          <div class="paterneTitleContainer">
            <span class="paterneTitle paterneTitleBlue">404</span><span
              class="paterneTitleContour">404</span>
          </div>
        </h1>
        <h3 class="h3 paterneTitleContourOnlyBlack">
          Il semblerait que la page soit introuvable...
        </h3>
        <div class="medium-spacing"></div>
      </section>
    </div>
  </div>
  
</BaseLayout>
