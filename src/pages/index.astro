---
import BaseLayout from "../layouts/BaseLayout.astro";

const schemaOrg = {
  "@context": "https://schema.org",
  "@type": "Organization",
  name: "Loooper!",
  url: "https://loooper.fr/",
  logo: "https://loooper.fr/img/logoSMP.png",
  sameAs: [
    "https://www.linkedin.com/company/loooper",
    "https://www.instagram.com/loooper_bdx/",
  ],
  description:
    "Loooper! propose des expériences ludiques et interactives sur mesure. Notre objectif : transformer vos contenus en moments ludiques, engageants, mémorables.",
};

import SaveSeamulator from "../components/Modal/SaveSeamulator.astro";
import Zizanie from "../components/Modal/Zizanie.astro";
import BikerAuGrandCoeur from "../components/Modal/BikerAuGrandCoeur.astro";
import CoopCook from "../components/Modal/CoopCook.astro";
import CartesCartels from "../components/Modal/CartesCartels.astro";
import Zemblanite from "../components/Modal/Zemblanite.astro";
---

<BaseLayout
  title="Loooper! – Ludification et expériences interactives sur mesure"
  description="Découvrez des expériences ludiques et interactives sur mesure. Notre objectif : transformer vos contenus en moments ludiques, engageants, mémorables."
  ogImage="https://loooper.fr/img/ico/ACCUEIL.png"
  ogUrl="https://loooper.fr"
  currentPage="index"
  schemaJson={schemaOrg}
>
  <div class="headerSpacing"></div>
  <div class="backgroundType2Annim left"></div>
  <div class="backgroundType2Annim right"></div>

  <section class="intro-paragraphe-container">
    <img
      class="backgroundType1Annim rightbackgroundType1 reflect"
      src="/svg/backgroundType1.svg"
      alt=""
    />
    <article class="intro-paragraphe">
      <h1 class="h2">
        Loooper!, c'est <span class="highlight orange">la ludification</span> au service
        de vos contenus.
      </h1>
      <div class="small-spacing"></div>
      <h2 class="h3">
        Loooper!, c'est l'alliance de <span class="highlight purple"
          >trois amis réunis</span
        > pour créer des moments vivants, engageants et inoubliables.
      </h2>
      <div class="small-spacing"></div>
      <h2 class="h3">
        Loooper!, c'est transformer n'importe quels contenus en <span
          class="highlight blue">solutions interactives</span
        > sur mesure pour mieux apprendre, mieux communiquer et s’émerveiller autrement.
      </h2>
      <div class="small-medium-spacing"></div>
      <a href="#contactForm" class="text-typo btn-project btn-white-background">
        <span>Lancer mon projet !</span>
        <div class="arrow-container black-arrow">
          <img src="/svg/arrowB.svg" alt="fleche" />
        </div>
      </a>
    </article>
    <img
      class="backgroundType1Annim leftbackgroundType1"
      src="/svg/backgroundType1.svg"
      alt=""
    />
  </section>

  <div class="large-spacing"></div>

  <div id="foot-inx4" class="backgroundBrushType1">
    <section class="container-width text-basical-container">
      <article class="text-basical-container-text">
        <div>
          <h2 class="h2 black white-border">L’équipe Loooper!</h2>
          <div class="small-medium-spacing"></div>
          <p>
            Nos chemins se sont croisés pendant nos études en <b>BUT MMI</b> (Métiers
            du Multimédia et de l'internet) à Bordeaux. Très vite, on a appris à travailler
            ensemble et surtout à <b>rêver ensemble.</b>
          </p>
          <div class="small-spacing"></div>
          <p>
            Ce qui nous unit ? L’envie de <b
              >transmettre, d’émerveiller, de créer du lien…</b
            > et de faire vivre la <b>ludification</b> sous toutes ses formes.
          </p>
          <div class="small-medium-spacing text-basical-container-footer-pc">
          </div>
          <div
            class="text-basical-container-footer text-basical-container-footer-pc"
          >
            <a
              href="/equipe/"
              class="text-typo btn-project btn-white-background"
            >
              <span>Rencontrer l’équipe</span>
            </a>
          </div>
        </div>
      </article>
      <article class="puzzle" id="puzzle"></article>
      <div
        class="text-basical-container-footer text-basical-container-footer-tel"
      >
        <a href="/equipe/" class="text-typo btn-project btn-white-background">
          <span>Rencontrer l’équipe</span>
        </a>
      </div>
    </section>
  </div>

  <div class="large-spacing"></div>

  <section
    id="foot-inx3"
    class="swiper"
    aria-label="Galerie d'images en carrousel"
  >
    <h2 class="h2 black white-border container-width">
      Notre savoir-faire en action !
    </h2>
    <div class="small-medium-spacing"></div>
    <div class="swiper-wrapper">
      <article class="swiper-slide">
        <button
          class="slide-media btn-modal"
          data-modal="modal-zizanie"
          aria-haspopup="dialog"
          aria-label="En savoir plus sur La Zizanie"
        >
          <img
            src="/img/carousel/zizanie.jpg"
           
            alt="Image représentant le projet La Zizanie"
          />
        </button>
        <div class="slide-caption">
          <h3 class="h3 highlight-no-annim white-border-small black orange">
            La Zizanie
          </h3>
          <p class="">Expérience interactive | MUSBA</p>
        </div>
      </article>

      <article class="swiper-slide">
        <button
          class="slide-media btn-modal"
          data-modal="modal-bikers"
          aria-haspopup="dialog"
          aria-label="En savoir plus sur Bikers au Grand cœur"
        >
          <img
            src="/img/carousel/biker.jpg"
           
            alt="Image représentant le projet Biker contre le harcèlement"
          />
        </button>
        <div class="slide-caption">
          <h3 class="h3 highlight-no-annim white-border-small black purple">
            Biker contre le harcèlement
          </h3>
          <p class="">Jeu de société | Association</p>
        </div>
      </article>

      <article class="swiper-slide">
        <button
          class="slide-media btn-modal"
          data-modal="modal-save-seamulator"
          aria-haspopup="dialog"
          aria-label="En savoir plus sur Save Seamulator"
        >
          <img
            src="/img/carousel/saveseamulator.jpg"
           
            alt="Image représentant le projet Save Seamulator"
          />
        </button>
        <div class="slide-caption">
          <h3 class="h3 highlight-no-annim white-border-small black blue">
            Save Seamulator
          </h3>
          <p class="">Jeu vidéo | Association</p>
        </div>
      </article>
      <article class="swiper-slide">
        <button
          class="slide-media btn-modal"
          data-modal="modal-zemblanite"
          aria-haspopup="dialog"
          aria-label="En savoir plus sur Zemblanité"
        >
          <img
            src="/img/carousel/zemblanite.jpg"
            loading="lazy"
            alt="Image représentant le projet Zemblanité"
          />
        </button>
        <div class="slide-caption">
          <h3 class="h3 highlight-no-annim white-border-small black orange">
            Zemblanité
          </h3>
          <p class="">Jeu vidéo | Projet étudiant</p>
        </div>
      </article>

      <article class="swiper-slide">
        <button
          class="slide-media btn-modal"
          data-modal="modal-coop-cook"
          aria-haspopup="dialog"
          class="text-typo btn-project btn-modal btn-white-background"
          aria-label="En savoir plus sur le Coop’Cook"
        >
          <img
            src="/img/carousel/coopCook.jpg"
            loading="lazy"
            alt="Image représentant le projet Coop’ Cook"
          />
        </button>
        <div class="slide-caption">
          <h3 class="h3 highlight-no-annim white-border-small black purple">
            Coop’ Cook
          </h3>
          <p class="">Jeu vidéo multijoueur | Projet étudiant</p>
        </div>
      </article>

      <article class="swiper-slide">
        <button
          class="slide-media btn-modal"
          data-modal="modal-cartes-cartels"
          aria-haspopup="dialog"
          aria-label="En savoir plus sur Cartes & Cartels"
        >
          <img
            src="/img/carousel/carteCartel.jpg"
            loading="lazy"
            alt="Image représentant le projet Cartes & Cartels"
          />
        </button>
        <div class="slide-caption">
          <h3 class="h3 highlight-no-annim white-border-small black blue">
            Cartes & Cartels
          </h3>
          <p class="">Expérience interative | MUSBA</p>
        </div>
      </article>
    </div>

    <div class="swiper-btn-container">
      <div class="swiper-container">
        <div class="swiper-button-prev" aria-label="Diapo précédente">
          <div class="barArrow barArrow1"></div>
          <div class="barArrow barArrow2"></div>
        </div>
        <div class="swiper-pagination" aria-label="Pagination"></div>
        <div class="swiper-button-next" aria-label="Diapo suivante">
          <div class="barArrow barArrow1"></div>
          <div class="barArrow barArrow2"></div>
        </div>
      </div>
      <a href="/projets/" class="text-typo btn-project btn-white-background">
        <span>Découvrir nos réalisations</span>
      </a>
    </div>
  </section>

  <div class="large-spacing"></div>

  <section id="foot-inx1" class="zoom-container-center">
    <div class="zoom-container">
      <div class="container-width">
        <article class="memory-game">
          <h2 class="h2 black">Mais qu’est-ce qui rend Loooper! unique ?</h2>
          <div class="small-medium-spacing"></div>
          <div class="memory-game-container">
            <div class="game-board">
              <div
                class="card"
                data-image="/svg/guyMemories.svg"
                alt="Carte 1 du mémories"
              >
              </div>
              <div
                class="card"
                data-image="/svg/linkMemories.svg"
                alt="Carte 2 du mémories"
              >
              </div>
              <div
                class="card"
                data-image="/svg/guyMemories.svg"
                alt="Carte 3 du mémories"
              >
              </div>
              <div
                class="card"
                data-image="/svg/targetMemories.svg"
                alt="Carte 4 du mémories"
              >
              </div>
              <div
                class="card"
                data-image="/svg/linkMemories.svg"
                alt="Carte 5 du mémories"
              >
              </div>
              <div
                class="card"
                data-image="/svg/targetMemories.svg"
                alt="Carte 6 du mémories"
              >
              </div>
            </div>
            <div class="game-info">
              <p class="text-typo">
                Cliquez <b>ici</b> pour relire les contenus <b>débloqués</b>.
              </p>
              <nav class="game-button-nav">
                <div class="game-button-arrow-container">
                  <img
                    class="game-btn-arrow"
                    src="/svg/arrow/Type3.svg"
                    alt=""
                    width="40"
                    height="40"
                  />
                  <div class="game-button">
                    <img src="/svg/interogationMemories.svg" />
                  </div>
                </div>
                <div class="game-button-arrow-container">
                  <img
                    class="game-btn-arrow"
                    src="/svg/arrow/Type2.svg"
                    alt=""
                    width="40"
                    height="40"
                  />
                  <div class="game-button">
                    <img src="/svg/interogationMemories.svg" />
                  </div>
                </div>
                <div class="game-button-arrow-container">
                  <img
                    class="game-btn-arrow"
                    src="/svg/arrow/Type1.svg"
                    alt=""
                    width="40"
                    height="40"
                  />
                  <div class="game-button">
                    <img src="/svg/interogationMemories.svg" />
                  </div>
                </div>
              </nav>
              <img
                id="game-image"
                src="/svg/interogationMemories.svg"
                alt="Image de la paire trouvée"
              />
              <div class="game-info-text">
                <h3 id="game-message-title" class="black h3">Un petit jeu ?</h3>
                <p id="game-message" class="black">
                  Trouve <b>les paires</b> pour découvrir <b
                    >la philosophie “Loooper!”</b
                  >!
                </p>
              </div>
            </div>
          </div>

          <div class="memory-no-game-container" style="display:none;">
            <article class="memory-no-game">
              <div class="memory-item">
                <img
                  src="/svg/guyMemories.svg"
                  alt="Pensé pour tous les publics"
                />
                <div class="memory-item-text orange-shadow-box">
                  <h3 class="h3">Formats hybrides</h3>
                  <p>
                    Numériques, physiques ou phygitaux, nos formats s’adaptent à
                    vos usages. Conscients des enjeux liés aux écrans, nous
                    veillons à proposer nos expériences sur le support le plus
                    adapté aux besoins de chacun.
                  </p>
                </div>
              </div>

              <div class="memory-item">
                <img
                  src="/svg/linkMemories.svg"
                  alt="Expérience créatrice de lien"
                />
                <div class="memory-item-text purple-shadow-box">
                  <h3 class="h3">Valeurs humaines</h3>
                  <p>
                    Chaque expérience est conçue pour être à la fois ludique,
                    accessible et inclusive. Ces valeurs sont essentielles pour
                    nous et guident chacune de nos créations.
                  </p>
                </div>
              </div>

              <div class="memory-item">
                <img
                  src="/svg/targetMemories.svg"
                  alt="Solutions adaptées sur mesure"
                />
                <div class="memory-item-text blueu-shadow-box">
                  <h3 class="h3">Créations sur mesure</h3>
                  <p>
                    De l’idée à la mise en œuvre, nous vous accompagnons pour
                    imaginer et réaliser des formats ludiques qui vous
                    ressemblent afin donner vie à une expérience unique alignée
                    avec vos attentes.
                  </p>
                </div>
              </div>
            </article>
          </div>

          <div class="small-medium-spacing"></div>
          <div class="memory-no-game-container-footer">
            <a
              href="/formats/"
              class="text-typo btn-project btn-white-background"
            >
              <span>Voir ce qu’on peut créer ensemble</span>
            </a>
          </div>
        </article>
      </div>
    </div>
  </section>

  <div class="large-spacing"></div>

  <section id="foot-inx2" class="container-width">
    <h2 class="h2 black white-border">
      Des expériences qui répondent à vos besoins :
    </h2>
    <div class="small-medium-spacing"></div>
    <nav class="mini-card-container">
      <a href="/apprendre-ludique/">
        <article class="revers-mini-card mini-card-orange">
          <h3 class="h3 black">Apprendre avec le ludique</h3>
          <img
            src="/svg/pictoMiniCard/idea.svg"
            alt="Image representant une idée"
          />
        </article>
      </a>

      <a href="/sensibiliser-reflechir/">
        <article class="mini-card mini-card-purple">
          <h3 class="h3 black">Sensibiliser et faire réfléchir</h3>
          <img
            src="/svg/pictoMiniCard/annonce.svg"
            alt="Image representant un megaphone"
          />
        </article>
      </a>

      <a href="/creer-interaction-sociale/">
        <article class="revers-mini-card mini-card-blue">
          <h3 class="h3 black">Créer de l'interaction sociale</h3>
          <img
            src="/svg/pictoMiniCard/connection.svg"
            alt="Image representant une des connection entre plusieur personne"
          />
        </article>
      </a>

      <a href="/former-efficacement/">
        <article class="mini-card mini-card-orange">
          <h3 class="h3 black">Former efficacement</h3>
          <img
            src="/svg/pictoMiniCard/teach.svg"
            alt="Image representant un couvre chef etudiant"
          />
        </article>
      </a>

      <a href="/renforcer-cohesion/">
        <article class="mini-card mini-card-purple">
          <h3 class="h3 black">Renforcer la cohésion</h3>
          <img
            src="/svg/pictoMiniCard/table.svg"
            alt="Image representant 4 personne autour d'une table"
          />
        </article>
      </a>

      <a href="/engager-motiver/">
        <article class="revers-mini-card mini-card-blue">
          <h3 class="h3 black">Engager et motiver</h3>
          <img
            src="/svg/pictoMiniCard/starPodium.svg"
            alt="Image representant un podium avec une étoile"
          />
        </article>
      </a>

      <a href="/communiquer-autrement/">
        <article class="mini-card mini-card-orange">
          <h3 class="h3 black">Communiquer autrement</h3>
          <img
            src="/svg/pictoMiniCard/bullTalking.svg"
            alt="Image representant des bulle de texte"
          />
        </article>
      </a>
    </nav>

    <div class="small-medium-spacing"></div>

    <div class="aligne-btn-center">
      <a href="/besoins/" class="text-typo btn-project btn-white-background">
        <span>Explorer mes besoins</span>
      </a>
    </div>
  </section>

  <div class="large-spacing"></div>

        <SaveSeamulator />
        <BikerAuGrandCoeur />
        <Zemblanite />
        <CoopCook />
        <CartesCartels />
        <Zizanie />

  <script src="/js/modal.js" defer></script>
  <script
    src="https://cdn.jsdelivr.net/npm/canvas-confetti@1.6.0/dist/confetti.browser.min.js"
    defer></script>
   <script src="/js/ramdomAparition.js" defer></script>
  <script src="/js/puzzleTaquin.js" defer></script>
  <script src="/js/swiper-bundle.min.js" defer></script>
  <script src="/js/carousel.js" defer></script>
  <script src="/js/3DEffect.js" defer></script>
  <script src="/js/memories.js" defer></script>
</BaseLayout>
