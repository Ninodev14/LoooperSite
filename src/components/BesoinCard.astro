---
/**
 * BesoinCard.astro
 * Carte "besoin" utilisée sur la page /besoins et autres listes.
 * Props :
 *   - href    : lien vers la page besoin
 *   - title   : titre du besoin
 *   - desc    : courte description
 *   - icon    : nom de fichier icône (dans /src/img/ico/)
 *   - color   : couleur d'accentuation ("purple" | "orange" | "yellow" | "green")
 */

interface Props {
  href: string;
  title: string;
  desc: string;
  icon?: string;
  color?: 'purple' | 'orange' | 'yellow' | 'green';
}

const { href, title, desc, icon, color = 'purple' } = Astro.props;
---

<a href={href} class:list={['besoin-card', `besoin-card--${color}`]}>
  {icon && (
    <div class="besoin-card-icon">
      <img src={`/src/img/ico/${icon}`} alt="" width="60" height="60" loading="lazy" />
    </div>
  )}
  <h3 class="besoin-card-title">{title}</h3>
  <p class="besoin-card-desc">{desc}</p>
  <span class="besoin-card-cta" aria-hidden="true">Découvrir →</span>
</a>
