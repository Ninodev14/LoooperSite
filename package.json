{
  "name": "looopersite",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "build:css": "postcss src/css/style.css -o src/css/style.min.css",
    "build:images": "node scripts/convert-images.js",
    "build:html-optimize": "node scripts/optimize-html.js",
    "build:html-css-ref": "node -e \"const fs=require('fs'),path=require('path');function find(d){fs.readdirSync(d).forEach(f=>{const p=path.join(d,f);if(fs.statSync(p).isDirectory()&&f!=='node_modules'&&f!=='.git')find(p);else if(f.endsWith('.html')){const c=fs.readFileSync(p,'utf8');fs.writeFileSync(p,c.replace(/src\\/css\\/style\\.css/g,'src/css/style.min.css'))}})}find('.')\"",
    "build": "npm run build:images && npm run build:css && npm run build:html-css-ref && npm run build:html-optimize"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Ninodev14/LoooperSite.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/Ninodev14/LoooperSite/issues"
  },
  "homepage": "https://github.com/Ninodev14/LoooperSite#readme",
  "devDependencies": {
    "cssnano": "^7.1.7",
    "jsdom": "^26.0.0",
    "postcss": "^8.5.12",
    "postcss-cli": "^11.0.1",
    "postcss-import": "^16.1.1",
    "sharp": "^0.34.5"
  }
}